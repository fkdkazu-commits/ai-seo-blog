---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, tags, ogImage, canonicalUrl } = post.data;

const heroImage = ogImage ?? `${import.meta.env.BASE_URL}og/${post.slug}.png`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  author: { '@type': 'Organization', name: 'AIメディア' },
};
---

<BaseLayout title={title} description={description} ogImage={heroImage} canonicalUrl={canonicalUrl} wide={true}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Breadcrumb -->
  <nav class="text-xs text-gray-400 mb-6 flex gap-2 items-center flex-wrap" aria-label="breadcrumb">
    <a href={import.meta.env.BASE_URL} class="hover:text-blue-500 transition-colors">ホーム</a>
    <span>›</span>
    <a href={`${import.meta.env.BASE_URL}blog/`} class="hover:text-blue-500 transition-colors">記事一覧</a>
    <span>›</span>
    <span class="text-gray-600 truncate max-w-xs">{title}</span>
  </nav>

  <div class="lg:grid lg:grid-cols-[1fr_260px] lg:gap-10 items-start">

    <!-- ─── Main Article ─── -->
    <article>

      <!-- Hero Image with overlay -->
      <div class="relative mb-8 rounded-2xl overflow-hidden shadow-lg">
        <img
          src={heroImage}
          alt={title}
          width="1200"
          height="630"
          class="w-full object-cover"
          loading="eager"
        />
        <!-- Gradient overlay at bottom -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
        <!-- Tags on image -->
        <div class="absolute bottom-4 left-4 flex gap-2 flex-wrap">
          {tags.map((tag) => (
            <span class="text-xs bg-white/20 backdrop-blur-sm text-white border border-white/30 px-2.5 py-1 rounded-full font-medium">{tag}</span>
          ))}
        </div>
      </div>

      <!-- Title -->
      <h1 class="text-2xl md:text-[1.75rem] font-bold leading-snug mb-4 text-gray-900 tracking-tight">{title}</h1>

      <!-- Meta bar -->
      <div class="flex flex-wrap items-center gap-3 text-xs text-gray-500 pb-5 mb-7 border-b border-gray-200">
        <span class="flex items-center gap-1.5 bg-gray-100 px-2.5 py-1 rounded-full">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          <time datetime={pubDate.toISOString()}>{pubDate.toLocaleDateString('ja-JP')} 公開</time>
        </span>
        {updatedDate && (
          <span class="flex items-center gap-1.5 bg-gray-100 px-2.5 py-1 rounded-full">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            <time datetime={updatedDate.toISOString()}>{updatedDate.toLocaleDateString('ja-JP')} 更新</time>
          </span>
        )}
        <span id="reading-time" class="flex items-center gap-1.5 bg-blue-50 text-blue-600 px-2.5 py-1 rounded-full">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          計算中...
        </span>
      </div>

      <!-- Mobile TOC -->
      <details class="lg:hidden bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-100 rounded-xl p-4 mb-8">
        <summary class="font-bold text-blue-800 cursor-pointer text-sm select-none flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"/></svg>
          目次を開く
        </summary>
        <nav id="toc-mobile" class="mt-3"></nav>
      </details>

      <!-- Article Content -->
      <div id="article-body" class="prose prose-gray max-w-none
        prose-p:leading-[1.9] prose-p:text-gray-700 prose-p:text-[0.95rem]
        prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline
        prose-strong:text-gray-900 prose-strong:font-bold
        prose-li:text-gray-700 prose-li:text-[0.95rem]
        prose-img:rounded-xl prose-img:shadow-md
        prose-pre:!bg-gray-900 prose-pre:rounded-xl prose-pre:shadow-lg
        prose-code:before:content-none prose-code:after:content-none
      ">
        <slot />
      </div>

      <!-- Share Buttons -->
      <div class="mt-12 pt-6 border-t border-gray-200">
        <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-4">この記事をシェアする</p>
        <div class="flex gap-3 flex-wrap">
          <a id="share-x" href="#" target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-2 bg-black text-white text-sm px-5 py-2.5 rounded-xl hover:bg-gray-800 transition-all font-medium shadow-sm">
            𝕏 でシェア
          </a>
          <a id="share-line" href="#" target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-2 bg-[#06C755] text-white text-sm px-5 py-2.5 rounded-xl hover:opacity-90 transition-all font-medium shadow-sm">
            LINE でシェア
          </a>
        </div>
      </div>

      <!-- Tags Footer -->
      <div class="mt-6 pt-5 border-t border-gray-100">
        <p class="text-xs text-gray-400 mb-2 uppercase tracking-widest">タグ</p>
        <div class="flex gap-2 flex-wrap">
          {tags.map((tag) => (
            <span class="text-xs bg-white border border-gray-200 text-gray-600 px-3 py-1 rounded-full hover:border-blue-300 hover:text-blue-600 transition-colors shadow-sm">{tag}</span>
          ))}
        </div>
      </div>

    </article>

    <!-- ─── Sidebar ─── -->
    <aside class="hidden lg:block">
      <div class="sticky top-20 space-y-5">

        <!-- TOC -->
        <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-sm">
          <div class="bg-gradient-to-r from-blue-600 to-indigo-600 px-5 py-3 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white/80" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"/>
            </svg>
            <p class="font-bold text-white text-sm">目次</p>
          </div>
          <div class="p-4">
            <nav id="toc-desktop"></nav>
          </div>
        </div>

        <!-- Article Info -->
        <div class="bg-white border border-gray-200 rounded-2xl p-5 shadow-sm space-y-3 text-xs text-gray-500">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <time datetime={pubDate.toISOString()}>{pubDate.toLocaleDateString('ja-JP')} 公開</time>
          </div>
          <div id="sidebar-reading-time" class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span>計算中...</span>
          </div>
          <div class="pt-3 border-t border-gray-100 flex gap-2">
            <a id="sidebar-share-x" href="#" target="_blank" rel="noopener noreferrer"
              class="flex-1 text-center py-2 bg-black text-white text-xs rounded-lg hover:bg-gray-800 transition-colors font-medium">
              𝕏
            </a>
            <a id="sidebar-share-line" href="#" target="_blank" rel="noopener noreferrer"
              class="flex-1 text-center py-2 bg-[#06C755] text-white text-xs rounded-lg hover:opacity-90 transition-colors font-medium">
              LINE
            </a>
          </div>
        </div>

      </div>
    </aside>

  </div>
</BaseLayout>

<style>
  /* ─── 見出し ─── */
  #article-body :global(h2) {
    font-size: 1.15rem;
    font-weight: 700;
    margin-top: 2.75rem;
    margin-bottom: 1rem;
    padding: 0.65rem 1rem 0.65rem 1rem;
    background: linear-gradient(135deg, #eff6ff 0%, #eef2ff 100%);
    border-left: 4px solid #3b82f6;
    border-radius: 0 10px 10px 0;
    color: #1e3a5f;
    scroll-margin-top: 80px;
    position: relative;
  }

  #article-body :global(h3) {
    font-size: 1rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.6rem;
    padding-left: 0.875rem;
    border-left: 3px solid #6366f1;
    color: #312e81;
    scroll-margin-top: 80px;
  }

  #article-body :global(h4) {
    font-size: 0.9rem;
    font-weight: 700;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: #374151;
    scroll-margin-top: 80px;
  }

  /* ─── 引用ブロック ─── */
  #article-body :global(blockquote) {
    border: none;
    background: linear-gradient(135deg, #f0f9ff, #f5f3ff);
    border-left: 4px solid #818cf8;
    border-radius: 0 12px 12px 0;
    padding: 1rem 1.25rem;
    font-style: normal;
    color: #312e81;
    margin: 1.5rem 0;
    position: relative;
  }

  #article-body :global(blockquote::before) {
    content: '"';
    position: absolute;
    top: -8px;
    left: 12px;
    font-size: 3rem;
    color: #818cf8;
    line-height: 1;
    opacity: 0.4;
    font-family: Georgia, serif;
  }

  #article-body :global(blockquote p) {
    margin: 0;
  }

  /* ─── インラインコード ─── */
  #article-body :global(code:not(pre code)) {
    background: linear-gradient(135deg, #fdf4ff, #fdf2f8);
    color: #9d174d;
    padding: 2px 7px;
    border-radius: 5px;
    font-size: 0.82em;
    font-weight: 600;
    border: 1px solid #fce7f3;
    letter-spacing: -0.01em;
  }

  /* ─── コードブロック ─── */
  #article-body :global(pre) {
    background-color: #1a1b26 !important;
    border-radius: 14px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    border: 1px solid #2d2f45;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
  }

  #article-body :global(pre code) {
    background: none !important;
    border: none !important;
    color: #a9b1d6 !important;
    font-size: 0.86rem;
    line-height: 1.75;
    padding: 0 !important;
    font-weight: 400;
  }

  /* ─── テーブル ─── */
  #article-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    margin: 1.5rem 0;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  #article-body :global(thead tr) {
    background: linear-gradient(135deg, #1e3a8a, #3730a3);
    color: white;
  }

  #article-body :global(th) {
    padding: 11px 16px;
    text-align: left;
    font-weight: 600;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
  }

  #article-body :global(td) {
    padding: 10px 16px;
    border-bottom: 1px solid #e2e8f0;
    color: #374151;
    font-size: 0.875rem;
  }

  #article-body :global(tbody tr:last-child td) {
    border-bottom: none;
  }

  #article-body :global(tbody tr:nth-child(even)) {
    background-color: #f8fafc;
  }

  #article-body :global(tbody tr:hover) {
    background-color: #eff6ff;
    transition: background-color 0.15s;
  }

  /* ─── 箇条書き ─── */
  #article-body :global(ul) {
    background: linear-gradient(135deg, #f8fafc, #f0f9ff);
    border: 1px solid #dbeafe;
    border-left: 4px solid #60a5fa;
    border-radius: 0 12px 12px 0;
    padding: 1rem 1rem 1rem 2.25rem;
    margin: 1.25rem 0;
  }

  #article-body :global(ul > li) {
    margin: 0.35rem 0;
    color: #374151;
    font-size: 0.95rem;
  }

  #article-body :global(ul > li::marker) {
    color: #3b82f6;
  }

  /* ─── 番号付きリスト ─── */
  #article-body :global(ol) {
    background: linear-gradient(135deg, #fffbeb, #fef3c7);
    border: 1px solid #fde68a;
    border-left: 4px solid #f59e0b;
    border-radius: 0 12px 12px 0;
    padding: 1rem 1rem 1rem 2.5rem;
    margin: 1.25rem 0;
  }

  #article-body :global(ol > li) {
    margin: 0.35rem 0;
    color: #374151;
    font-size: 0.95rem;
  }

  #article-body :global(ol > li::marker) {
    color: #d97706;
    font-weight: 700;
  }

  /* ネストしたリスト */
  #article-body :global(ul ul),
  #article-body :global(ul ol),
  #article-body :global(ol ul),
  #article-body :global(ol ol) {
    background: none;
    border: none;
    border-left: 2px solid #e2e8f0;
    border-radius: 0;
    padding: 0.25rem 0 0.25rem 1.25rem;
    margin: 0.25rem 0;
  }

  /* ─── TOC ─── */
  #toc-desktop a,
  #toc-mobile a {
    display: block;
    font-size: 0.73rem;
    line-height: 1.5;
    padding: 4px 6px 4px 10px;
    border-left: 2px solid transparent;
    color: #64748b;
    text-decoration: none;
    transition: all 0.15s;
    margin-bottom: 1px;
    border-radius: 0 4px 4px 0;
  }

  #toc-desktop a:hover,
  #toc-mobile a:hover {
    color: #2563eb;
    border-left-color: #93c5fd;
    background-color: #eff6ff;
  }

  #toc-desktop a.active,
  #toc-mobile a.active {
    color: #1d4ed8;
    border-left-color: #3b82f6;
    font-weight: 600;
    background-color: #eff6ff;
  }

  #toc-desktop a[data-level="h3"],
  #toc-mobile a[data-level="h3"] {
    padding-left: 20px;
    color: #94a3b8;
    font-size: 0.68rem;
  }
</style>

<script>
  // ── 読了時間 ──
  const body = document.getElementById('article-body');
  if (body) {
    const chars = body.innerText.replace(/\s+/g, '').length;
    const min = Math.max(1, Math.ceil(chars / 600));
    const label = `約${min}分`;
    const rt = document.getElementById('reading-time');
    const srt = document.getElementById('sidebar-reading-time');
    if (rt) rt.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>${label}で読めます`;
    if (srt) srt.querySelector('span')!.textContent = label + 'で読めます';
  }

  // ── TOC ──
  const headings = Array.from(
    document.querySelectorAll<HTMLElement>('#article-body h2, #article-body h3')
  );

  function buildToc(container: HTMLElement | null) {
    if (!container || headings.length === 0) return;
    const ul = document.createElement('ul');
    ul.style.cssText = 'list-style:none;margin:0;padding:0';
    headings.forEach((h, i) => {
      if (!h.id) h.id = `h-${i}`;
      const a = document.createElement('a');
      a.href = `#${h.id}`;
      a.textContent = h.textContent ?? '';
      a.dataset.level = h.tagName.toLowerCase();
      const li = document.createElement('li');
      li.appendChild(a);
      ul.appendChild(li);
    });
    container.appendChild(ul);
  }

  buildToc(document.getElementById('toc-desktop'));
  buildToc(document.getElementById('toc-mobile'));

  // ── スクロールハイライト ──
  const allLinks = document.querySelectorAll<HTMLAnchorElement>('#toc-desktop a, #toc-mobile a');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          allLinks.forEach((link) => {
            link.classList.toggle('active', link.hash === `#${entry.target.id}`);
          });
        }
      });
    },
    { rootMargin: '-15% 0px -70% 0px' }
  );
  headings.forEach((h) => observer.observe(h));

  // ── シェアボタン ──
  const url = encodeURIComponent(location.href);
  const text = encodeURIComponent(document.title);
  const links: [string, string][] = [
    ['share-x', `https://twitter.com/intent/tweet?url=${url}&text=${text}`],
    ['share-line', `https://line.me/R/msg/text/?${text}%0A${url}`],
    ['sidebar-share-x', `https://twitter.com/intent/tweet?url=${url}&text=${text}`],
    ['sidebar-share-line', `https://line.me/R/msg/text/?${text}%0A${url}`],
  ];
  links.forEach(([id, href]) => {
    const el = document.getElementById(id) as HTMLAnchorElement | null;
    if (el) el.href = href;
  });
</script>
