---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
  wide?: boolean;
}

const { title, description, ogImage, canonicalUrl, wide = false } = Astro.props;
const siteUrl = 'https://fkdkazu-commits.github.io';
const canonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).toString();
const og = ogImage || `${siteUrl}/og-default.png`;
const gscVerification = import.meta.env.GOOGLE_SITE_VERIFICATION;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- OGP -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={og} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={og} />

    {gscVerification && <meta name="google-site-verification" content={gscVerification} />}

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />

    <style>
      body { font-family: 'Noto Sans JP', -apple-system, BlinkMacSystemFont, sans-serif; }
    </style>
  </head>
  <body class="bg-gray-50 text-gray-900">

    <!-- Header -->
    <header class="border-b border-gray-200 bg-white sticky top-0 z-50 shadow-sm">
      <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href={import.meta.env.BASE_URL} class="flex items-center gap-2 group">
          <span class="w-7 h-7 rounded-lg bg-blue-600 flex items-center justify-center text-white text-xs font-black">AI</span>
          <span class="font-bold text-gray-900 group-hover:text-blue-600 transition-colors">AIメディア</span>
        </a>
        <nav class="flex items-center gap-1 text-sm">
          <a href={`${import.meta.env.BASE_URL}blog/`}
            class="px-3 py-1.5 rounded-lg text-gray-600 hover:text-blue-600 hover:bg-blue-50 transition-all font-medium">
            記事一覧
          </a>
        </nav>
      </div>
    </header>

    <main class={`${wide ? 'max-w-5xl' : 'max-w-3xl'} mx-auto px-6 py-10`}>
      <slot />
    </main>

    <footer class="bg-gray-900 text-gray-400 py-12 mt-16">
      <div class="max-w-5xl mx-auto px-6">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <div class="flex items-center gap-2">
            <span class="w-7 h-7 rounded-lg bg-blue-500 flex items-center justify-center text-white text-xs font-black">AI</span>
            <span class="font-bold text-white">AIメディア</span>
          </div>
          <p class="text-sm text-center">AI・SEO・業務効率化の実践情報メディア</p>
          <p class="text-xs">&copy; {new Date().getFullYear()} All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
